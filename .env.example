# Anthropic — used ONLY by the content generator scripts (not at site runtime)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — used by lib/llm to log generator usage (metadata only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public base URL — used for canonical URLs, OG tags, JSON-LD
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
